# ---- CivicPulse environment ----

# Google Gemini API key (from Google AI Studio: https://aistudio.google.com/apikey)
# If omitted, the app runs in a fully-functional MOCK mode so the prototype still works.
GEMINI_API_KEY=

# Model used for the agent pipeline (multimodal capable).
GEMINI_MODEL=gemini-2.5-flash

# Embedding model used by the semantic Deduplication Agent.
GEMINI_EMBED_MODEL=text-embedding-004

# Canonical site URL (used for SEO metadata, sitemap, robots, Open Graph).
# Set to your deployed URL, e.g. https://civicpulse.example.com
# SITE_URL is read at runtime (no rebuild needed); NEXT_PUBLIC_SITE_URL is baked at build time.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Analytics 4 measurement ID. Leave blank to disable analytics.
NEXT_PUBLIC_GA_ID=

# Secret used to sign RBAC session cookies (JWT). Set a long random string in production.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Optional: port (Cloud Run sets PORT automatically)
PORT=3000
